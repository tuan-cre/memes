{
  "manifest_version": 3,
  "name": "Meme Collection",
  "version": "1.0",
  "description": "Right-click any image to save it directly to your Meme Collection",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "key": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "me.memes.collection@neon",
      "strict_min_version": "109.0"
    }
  }
}
